    "dev": "vitest",
    "lint": "eslint src tests",
    "seed-sync": "node dist/src/cli/seedSync.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.7.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
