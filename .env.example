# Falsify environment contract — copy to .env and fill in locally. NEVER commit .env.
# The secret value is NOT stored here; Falsify reuses the same variables Plan Forge
# already sets on this machine.

# OpenBrain (Corpus memory tier). Reuses your existing machine-level vars.
# Key is a 64-char hex MCP access key — keep it secret, never commit it.
OPENBRAIN_KEY=

# Memory endpoints (the same key authorizes both):
#   Public REST/MCP (portable, used in deployment + REST calls):
OPENBRAIN_REST_BASE=https://brain.planforge.software
#   Private MCP-SSE (Tailscale-only, local dev):
OPENBRAIN_URL=https://openbrain.tailfb4202.ts.net/sse

# Project scope for every memory Falsify reads/writes.
FALSIFY_BRAIN_PROJECT=falsify
